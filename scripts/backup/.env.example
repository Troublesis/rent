# =============================================================================
# Rent backup script — environment template
# Copy this file to `.env` in the same directory and fill in real values.
#   cp .env.example .env && chmod 600 .env
# =============================================================================

# --- Source data ------------------------------------------------------------
# Absolute path to the SQLite database file.
DB_PATH=/absolute/path/to/rent/data/rent.db

# Absolute path to the rent app's runtime `.env` file. This is included in the
# archive so admin/session secrets are preserved alongside the DB.
# Leave empty to skip (NOT recommended — restores will need manual env rebuild).
APP_ENV_FILE=/absolute/path/to/rent/.env

# --- WebDAV target ----------------------------------------------------------
# Base URL pointing at the directory backups live in. MUST end with a slash.
# The directory must already exist on the server (script does not MKCOL).
# Examples:
#   Nextcloud: https://cloud.example.com/remote.php/dav/files/<user>/backups/rent/
#   dufs:      https://dav.example.com/rent/
#   AList:     https://alist.example.com/dav/rent/
WEBDAV_URL=https://dav.example.com/rent/
WEBDAV_USER=backup-user
WEBDAV_PASS=change-me

# --- Rotation ---------------------------------------------------------------
# Keep the most recent N archives on the remote; delete the rest after each run.
BACKUP_KEEP_N=30
# Filename prefix. Final archive: <prefix>-YYYYMMDDTHHMMSSZ.tar.gz
BACKUP_PREFIX=rent

# --- Bark notifications -----------------------------------------------------
# Bark server base URL (self-hosted or the default https://api.day.app).
BARK_URL=https://api.day.app
BARK_KEY=your-bark-device-key
BARK_GROUP=rent-backup
# Optional icon URL displayed in the push notification.
BARK_ICON=
# Set to 0 to only notify on failure (failures always notify).
BARK_NOTIFY_ON_SUCCESS=1

# --- Behavior ---------------------------------------------------------------
# Max seconds for the upload curl call. Increase for large DBs / slow links.
UPLOAD_TIMEOUT=300
# Lock file to prevent overlapping runs (used via flock when available).
LOCK_FILE=/tmp/rent-backup.lock
# Optional: also append timestamped log lines to this file. Empty = stderr only.
LOG_FILE=
